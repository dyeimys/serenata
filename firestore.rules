rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /rsvpSubmissions/{submissionId} {
      allow read: if signedIn();
      allow create: if true;
      allow update, delete: if false;
    }

    match /giftRegistryItems/{giftId} {
      allow read, write: if signedIn();
    }

    match /tasks/{taskId} {
      allow read, write: if signedIn();
    }

    match /agendaEvents/{eventId} {
      allow read, write: if signedIn();
    }

    match /settings/gifts {
      allow read: if true;
      allow write: if signedIn();
    }

    match /settings/weddingProfile {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /auditLogs/{logId} {
      allow read, create: if signedIn();
      allow update, delete: if false;
    }

    // Conversas, propostas e cotas sao acessadas somente pelas Cloud Functions.
    match /chatThreads/{threadId} {
      allow read, write: if false;
      match /messages/{messageId} {
        allow read, write: if false;
      }
      match /proposals/{proposalId} {
        allow read, write: if false;
      }
    }

    match /assistantUsage/{usageId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
