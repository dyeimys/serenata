rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function canManageGiftDeletion() {
      return userRole() in [
        'Noivo',
        'Noiva',
        'Assessor',
        'Assessora',
        'Assessor(a)',
        'Cerimonialista',
        'planner',
        'bride',
        'groom'
      ];
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /rsvpSubmissions/{submissionId} {
      allow read: if signedIn();
      allow create: if true;
      allow update, delete: if false;
    }

    match /giftRegistryItems/{giftId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if signedIn() && canManageGiftDeletion() && resource.data.disabled == true;
    }

    match /tasks/{taskId} {
      allow read, write: if signedIn();
    }

    match /agendaEvents/{eventId} {
      allow read, write: if signedIn();
    }

    match /settings/gifts {
      allow read: if true;
      allow write: if signedIn();
    }

    match /settings/weddingProfile {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /auditLogs/{logId} {
      allow read, create: if signedIn();
      allow update, delete: if false;
    }

    // Conversas, propostas e cotas sao acessadas somente pelas Cloud Functions.
    match /chatThreads/{threadId} {
      allow read, write: if false;
      match /messages/{messageId} {
        allow read, write: if false;
      }
      match /proposals/{proposalId} {
        allow read, write: if false;
      }
    }

    match /assistantUsage/{usageId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
